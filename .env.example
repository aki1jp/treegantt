# ポート設定
# 変更する場合: cp .env.example .env して値を編集
FRONTEND_PORT=3000
PORT=4000
WS_PORT=4001

# Frontend (ブラウザから直接 API/WS に接続する場合)
VITE_API_URL=http://localhost:4000
VITE_WS_URL=ws://localhost:4001

# API
DB_PATH=/app/data/treegantt.db

# バックアップ（起動時1回 + 定期実行。api/src/config.ts が既定値を解決）
# 未設定時の既定: DB ファイルと同じディレクトリ配下の `backups/`
# BACKUP_DIR=/app/data/backups
# バックアップ間隔（時間）。既定 24。0 で定期実行を無効化（起動時の1回は実行される）
# BACKUP_INTERVAL_HOURS=24
# 保持するバックアップ世代数。既定 7。超過分は古い順に削除
# BACKUP_RETENTION=7

LDAP_ENABLED=false
# CORS 許可オリジン（REST・WebSocket 双方の Origin 検証に使用）。
# 既定は '*'（全許可、社内 LAN 運用向け）。本番でインターネット公開する場合は
# 具体的なオリジン1つを設定することを推奨する（例: CORS_ORIGIN=https://gantt.example.co.jp）。
CORS_ORIGIN=http://localhost:3000

# Phase 2: LDAP (未使用)
# LDAP_URL=ldap://your-ldap-server:389
# LDAP_BASE_DN=dc=example,dc=com
