{
  "name": "treegantt-api",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && cp -r src/db/migrations dist/db/migrations",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.0",
    "better-sqlite3": "^9.4.0",
    "fast-jwt": "^3.3.0",
    "fastify": "^4.27.0",
    "ldapjs": "^3.0.0",
    "uuid": "^10.0.0",
    "ws": "^8.20.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/ldapjs": "^2.2.0",
    "@types/node": "^20.0.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.7",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.7"
  }
}
